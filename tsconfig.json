{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"],
      "@assets/*": ["../assets/*"] // was "assets/*"
    }
  },
  "include": [
    "App.tsx",
    "src",
    "assets",
    "scripts",
    "src/shared/types",
    "types"
  ],
  "exclude": ["node_modules", "Pods"]
}
